<!-- 首页 - 商品列表展示 -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <icon type="search" size="16" color="#999" />
      <input 
        class="search-field" 
        placeholder="搜索商品" 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <icon 
        wx:if="{{searchKeyword}}" 
        type="clear" 
        size="16" 
        color="#999" 
        bindtap="onClearSearch"
      />
    </view>
  </view>

  <!-- 横幅图片轮播 -->
  <view class="banner">
    <swiper 
      class="banner-swiper" 
      indicator-dots 
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#1296db"
      circular 
      autoplay 
      interval="4000"
      duration="500"
    >
      <swiper-item wx:for="{{banners}}" wx:key="index">
        <image src="{{item}}" mode="aspectFill" class="banner-image"></image>
      </swiper-item>
    </swiper>
  </view>

  <!-- 分类入口 -->
  <view class="category-section">
    <view class="category-item" wx:for="{{categories}}" wx:key="name" bindtap="onCategoryTap" data-category="{{item.name}}">
      <view class="category-icon" style="background-color: {{item.color}};">
        <text>{{item.icon}}</text>
      </view>
      <text class="category-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 商品列表标题 -->
  <view class="section-header">
    <text class="section-title">
      {{searchKeyword ? '搜索: ' + searchKeyword : (selectedCategory || '热门推荐')}}
    </text>
    <text class="section-more" wx:if="{{selectedCategory}}" bindtap="onClearCategory">全部商品</text>
    <text class="section-more" wx:if="{{searchKeyword}}" bindtap="onClearSearch">清除搜索</text>
  </view>

  <!-- 商品列表 - 使用 wx:for 循环渲染 -->
  <view class="product-list">
    <view class="product-item" wx:for="{{products}}" wx:key="id" bindtap="onProductTap" data-id="{{item.id}}">
      <image src="{{item.imageUrl || item.image}}" class="p-img" mode="aspectFill"></image>
      <view class="p-info">
        <text class="p-name">{{item.name}}</text>
        <view class="p-tags">
          <text class="p-category">{{item.category}}</text>
        </view>
        <view class="p-bottom">
          <text class="p-price">￥{{item.price}}</text>
          <view class="add-btn" catchtap="addToCart" data-item="{{item}}">
            <text>+</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{products.length === 0}}">
    <text>暂无商品</text>
  </view>
</view>

