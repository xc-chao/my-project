<!-- 商品详情页 -->
<view class="detail-page">
  <!-- 商品图片轮播 -->
  <swiper class="product-swiper" indicator-dots circular>
    <swiper-item>
      <image src="{{product.imageUrl || product.image}}" mode="aspectFill" class="product-image"></image>
    </swiper-item>
  </swiper>
  
  <!-- 商品基本信息 -->
  <view class="product-info">
    <view class="price-section">
      <text class="price">￥{{product.price}}</text>
      <text class="stock">库存: {{product.stock}}</text>
    </view>
    <text class="name">{{product.name}}</text>
    <view class="tags">
      <text class="tag">{{product.category}}</text>
      <text class="tag">{{product.barcode}}</text>
    </view>
  </view>
  
  <!-- 商品描述 -->
  <view class="description-section">
    <view class="section-title">
      <text>商品详情</text>
    </view>
    <text class="description">{{product.description || '暂无描述'}}</text>
  </view>
  
  <!-- 规格选择（数量） -->
  <view class="spec-section" bindtap="onShowSpec">
    <text class="label">选择数量</text>
    <view class="spec-value">
      <text>已选: {{quantity}} 件</text>
      <text class="arrow">></text>
    </view>
  </view>
  
  <!-- 底部操作栏 - 使用 Vant Weapp -->
  <van-goods-action>
    <van-goods-action-icon 
      icon="cart-o" 
      text="购物车"
      badge="{{cartCount > 0 ? cartCount : ''}}"
      bind:click="onGoToCart"
    />
    <van-goods-action-icon 
      icon="shop-o" 
      text="店铺"
    />
    <van-goods-action-button 
      text="加入购物车" 
      type="warning"
      bind:click="onAddToCart"
    />
    <van-goods-action-button 
      text="立即购买"
      bind:click="onBuyNow"
    />
  </van-goods-action>
</view>

<!-- 规格选择弹窗 -->
<view class="spec-popup {{showSpec ? 'show' : ''}}" catchtap="onHideSpec">
  <view class="spec-content" catchtap="stopPropagation">
    <view class="spec-header">
      <image src="{{product.imageUrl}}" class="spec-image"></image>
      <view class="spec-info">
        <text class="spec-price">￥{{product.price}}</text>
        <text class="spec-stock">库存: {{product.stock}}</text>
      </view>
    </view>
    
    <view class="quantity-selector">
      <text class="label">购买数量</text>
      <view class="stepper">
        <button class="btn-minus" bindtap="onMinus" disabled="{{quantity <= 1}}">-</button>
        <input class="quantity-input" value="{{quantity}}" type="number" disabled />
        <button class="btn-plus" bindtap="onPlus" disabled="{{quantity >= product.stock}}">+</button>
      </view>
    </view>
    
    <button class="confirm-btn" bindtap="onConfirmSpec">确定</button>
  </view>
</view>

