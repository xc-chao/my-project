/* 商品详情页样式 */

.detail-page {
  padding-bottom: 120rpx;
}

/* 商品图片轮播 */
.product-swiper {
  width: 100%;
  height: 750rpx;
  background-color: #f5f5f5;
}

.product-image {
  width: 100%;
  height: 100%;
}

/* 商品信息 */
.product-info {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.price-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.price {
  font-size: 48rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.stock {
  font-size: 24rpx;
  color: #999;
}

.name {
  font-size: 32rpx;
  color: #333;
  line-height: 1.5;
  display: block;
  margin-bottom: 20rpx;
}

.tags {
  display: flex;
  gap: 10rpx;
}

.tag {
  padding: 8rpx 16rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #666;
}

/* 商品描述 */
.description-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.description {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 规格选择 */
.spec-section {
  background-color: #fff;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid #f0f0f0;
}

.label {
  font-size: 28rpx;
  color: #333;
}

.spec-value {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999;
}

.arrow {
  margin-left: 10rpx;
  color: #ccc;
}

/* 底部操作栏 - 使用 Vant 后无需这些样式 */
/* van-goods-action 已自带样式 */

/* 规格选择弹窗 */
.spec-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.spec-popup.show {
  opacity: 1;
  visibility: visible;
}

.spec-content {
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding: 40rpx;
  transform: translateY(100%);
  transition: transform 0.3s;
}

.spec-popup.show .spec-content {
  transform: translateY(0);
}

.spec-header {
  display: flex;
  margin-bottom: 40rpx;
}

.spec-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.spec-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.spec-price {
  font-size: 36rpx;
  color: #ff4d4f;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.spec-stock {
  font-size: 24rpx;
  color: #999;
}

.quantity-selector {
  margin-bottom: 40rpx;
}

.quantity-selector .label {
  display: block;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.stepper {
  display: flex;
  align-items: center;
}

.btn-minus,
.btn-plus {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  margin: 0;
  border-radius: 8rpx;
  color: #444444;
  background-color:rgba(148, 146, 146, 0.1);
  font-size: 32rpx;
}

.quantity-input {
  width: 100rpx;
  height: 60rpx;
  text-align: center;
  margin: 0 20rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
}

