<!-- 个人中心页面 -->
<view class="container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <block wx:if="{{userInfo}}">
      <image src="{{userInfo.avatar}}" class="avatar"></image>
      <view class="info">
        <text class="nickname">{{userInfo.nickname}}</text>
        <text class="phone">{{userInfo.phone || '未绑定手机号'}}</text>
      </view>
    </block>
    <block wx:else>
      <button class="login-btn" bindtap="onLogin">点击登录</button>
    </block>
  </view>

  <!-- 余额显示 -->
  <view class="balance-card" wx:if="{{userInfo}}">
    <text class="label">账户余额</text>
    <text class="amount">￥{{balance}}</text>
  </view>

  <!-- 订单统计 -->
  <view class="order-stats" wx:if="{{userInfo}}">
    <text class="title">我的订单</text>
    <view class="stats-list">
      <view class="stat-item" bindtap="onOrderNav" data-status="0">
        <text class="icon">⏰</text>
        <text class="count">{{orderStats.pending || 0}}</text>
        <text class="label">待支付</text>
      </view>
      <view class="stat-item" bindtap="onOrderNav" data-status="1">
        <text class="icon">✅</text>
        <text class="count">{{orderStats.paid || 0}}</text>
        <text class="label">已支付</text>
      </view>
      <view class="stat-item" bindtap="onOrderNav" data-status="3">
        <text class="icon">🎉</text>
        <text class="count">{{orderStats.completed || 0}}</text>
        <text class="label">已完成</text>
      </view>
      <view class="stat-item" bindtap="goToOrders">
        <text class="icon">📋</text>
        <text class="count">{{orderStats.total || 0}}</text>
        <text class="label">全部</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 - 使用 Vant Weapp -->
  <van-cell-group title="功能菜单">
    <van-cell title="我的订单" is-link bindtap="goToOrders">
      <van-icon slot="icon" name="orders-o" class="cell-icon" />
    </van-cell>
    <van-cell title="我的余额" is-link value="¥{{balance}}">
      <van-icon slot="icon" name="balance-o" class="cell-icon" />
    </van-cell>
    <van-cell title="关于我们" is-link bindtap="onAbout">
      <van-icon slot="icon" name="info-o" class="cell-icon" />
    </van-cell>
  </van-cell-group>
</view>

