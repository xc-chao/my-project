<!-- 购物车页面 - 使用 Vant Weapp -->
<view class="container">
  <!-- 未登录状态 -->
  <van-empty wx:if="{{!isLoggedIn}}" description="购物车空空如也~" image="https://img.yzcdn.cn/vant/custom-empty-image.png">
    <van-button round type="primary" bindtap="onGoLogin" class="empty-btn">去登录</van-button>
  </van-empty>
  
  <!-- 已登录但购物车为空 -->
  <van-empty wx:elif="{{isLoggedIn && cartItems.length === 0}}" description="快去挑选喜欢的商品吧" image="https://img.yzcdn.cn/vant/empty-image-default.png">
    <van-button round type="primary" bindtap="onGoShopping" class="empty-btn">去逛逛</van-button>
  </van-empty>

  <!-- 购物车列表 -->
  <view wx:else class="cart-content">
    <!-- 顶部工具栏 -->
    <van-cell-group>
      <van-cell>
        <view slot="title" class="toolbar">
          <van-checkbox value="{{allSelected}}" bind:change="onSelectAll">全选</van-checkbox>
        </view>
        <view slot="right-icon" class="toolbar-actions">
          <van-button size="small" plain type="danger" bindtap="onDeleteSelected">删除选中</van-button>
          <van-button size="small" plain bindtap="onClearCart">清空购物车</van-button>
        </view>
      </van-cell>
    </van-cell-group>

    <!-- 商品列表 -->
    <view class="cart-list">
      <van-swipe-cell wx:for="{{cartItems}}" wx:key="id" right-width="{{65}}">
        <!-- 商品项容器 -->
        <view class="cart-item-container">
          <!-- 复选框 -->
          <view class="checkbox-wrapper">
            <van-checkbox 
              value="{{item.selected}}" 
              bind:change="onToggleSelect"
              data-id="{{item.id}}"
              data-selected="{{item.selected}}"
            />
          </view>
          
          <!-- 商品卡片 - 可点击跳转详情 -->
          <view class="card-wrapper" bindtap="onProductTap" data-product-id="{{item.product.id}}">
            <van-card
              price="{{item.product.price}}"
              title="{{item.product.name}}"
              thumb="{{item.product.imageUrl}}"
              custom-class="cart-card"
            >
              <view slot="tags">
                <van-tag plain type="primary">{{item.product.category}}</van-tag>
              </view>
              <view slot="num">
                <view class="stepper-wrapper" catchtap="stopPropagation">
                  <van-stepper 
                    value="{{item.quantity}}" 
                    min="{{1}}"
                    max="{{item.product.stock}}"
                    bind:change="onStepperChange"
                    data-id="{{item.id}}"
                  />
                </view>
              </view>
            </van-card>
          </view>
        </view>
        
        <!-- 左滑删除 -->
        <view slot="right" class="delete-button" bindtap="onDeleteSwipe" data-id="{{item.id}}">
          删除
        </view>
      </van-swipe-cell>
    </view>
  </view>
  
  <!-- 结算栏 -->
  <view wx:if="{{isLoggedIn && cartItems.length > 0}}" class="submit-bar">
    <view class="bar-left">
      <van-checkbox value="{{allSelected}}" bind:change="onSelectAll">全选</van-checkbox>
    </view>
    <view class="bar-right">
      <view class="price-section">
        <text class="label">合计：</text>
        <text class="price">¥{{total.totalAmount || 0}}</text>
      </view>
      <button class="submit-button" bindtap="onCheckout" disabled="{{total.selectedCount === 0}}">
        结算({{total.selectedCount || 0}})
      </button>
    </view>
  </view>
</view>

