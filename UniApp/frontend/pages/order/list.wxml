<!-- 订单列表页 -->
<view class="order-list-page">
  <!-- 状态筛选标签 -->
  <view class="tabs">
    <view class="tab {{currentTab === -1 ? 'active' : ''}}" bindtap="onTabChange" data-status="-1">
      全部
    </view>
    <view class="tab {{currentTab === 0 ? 'active' : ''}}" bindtap="onTabChange" data-status="0">
      待支付<text class="badge" wx:if="{{orderStats.pending > 0}}">{{orderStats.pending}}</text>
    </view>
    <view class="tab {{currentTab === 1 ? 'active' : ''}}" bindtap="onTabChange" data-status="1">
      已支付<text class="badge" wx:if="{{orderStats.paid > 0}}">{{orderStats.paid}}</text>
    </view>
    <view class="tab {{currentTab === 3 ? 'active' : ''}}" bindtap="onTabChange" data-status="3">
      已完成
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list" wx:if="{{orders.length > 0}}">
    <view class="order-item" wx:for="{{orders}}" wx:key="id">
      <!-- 订单头部 -->
      <view class="order-header" bindtap="onOrderTap" data-id="{{item.id}}">
        <text class="order-no">订单号: {{item.orderNo}}</text>
        <text class="order-status status-{{item.status}}">{{getStatusText(item.status)}}</text>
      </view>

      <!-- 商品列表 -->
      <view class="order-products" bindtap="onOrderTap" data-id="{{item.id}}">
        <view class="product-item" wx:for="{{item.orderItems}}" wx:key="id" wx:for-item="product">
          <image src="{{product.product.imageUrl}}" class="product-img" mode="aspectFill"></image>
          <view class="product-info">
            <text class="product-name">{{product.product.name}}</text>
            <view class="product-bottom">
              <text class="product-price">￥{{product.price}}</text>
              <text class="product-quantity">x{{product.quantity}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 订单底部 -->
      <view class="order-footer">
        <text class="total-amount">实付: <text class="amount">￥{{item.totalAmount}}</text></text>
        <view class="buttons">
          <button wx:if="{{item.status === 0}}" class="btn btn-cancel" catchtap="onCancelOrder" data-id="{{item.id}}">取消订单</button>
          <button wx:if="{{item.status === 0}}" class="btn btn-pay" catchtap="onPayOrder" data-id="{{item.id}}">去支付</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:else>
    <text class="empty-icon">📦</text>
    <text class="empty-text">暂无订单</text>
  </view>
</view>
