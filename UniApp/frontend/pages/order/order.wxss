.order-list {
  padding: 20rpx;
}

.order-item {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.sn {
  font-size: 26rpx;
  color: #666;
}

.status {
  font-size: 26rpx;
  color: #1296db;
  font-weight: bold;
}

.order-body {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total {
  font-size: 32rpx;
  font-weight: bold;
  color: #e4393c;
}

.time {
  font-size: 24rpx;
  color: #999;
}

