# ==========================================
# ScanShop 后端环境变量配置模板
# 使用说明：
# 1. 复制此文件为 .env
# 2. 修改下方配置为你的实际值
# 3. 不要将 .env 文件提交到 Git
# ==========================================

# 服务器配置
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=your_mysql_password_here
DB_NAME=scanshop_db
DB_DIALECT=mysql

# JWT 密钥（请修改为随机字符串）
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 微信小程序配置（真实环境需要）
# WECHAT_APPID=your_wechat_appid
# WECHAT_SECRET=your_wechat_secret

# 开发环境配置
NODE_ENV=development

# 日志配置
LOG_LEVEL=info

